# Server-wide settings only.
# Public hostnames now live in the files under caddy/sites/.
# Example:
# ACME_EMAIL=ops@nxt-solutions.com
ACME_EMAIL=ops@example.com
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-this-now

# Optional settings:
TZ=UTC
SSH_DISABLE_PASSWORD_AUTH=true
ENABLE_UFW=true
ENABLE_FAIL2BAN=true
